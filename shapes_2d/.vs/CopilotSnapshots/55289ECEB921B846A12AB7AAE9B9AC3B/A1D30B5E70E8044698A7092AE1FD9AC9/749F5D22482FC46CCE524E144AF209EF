using System;
using System.Drawing;
using System.Drawing.Drawing2D;
using System.Windows.Forms;

namespace shapes_2d
{
    public partial class FrmTrapecio : Form
    {
        private double B = 0; // base mayor
        private double b = 0; // base menor
        private double h = 0; // altura
        private double lateral1 = 0;
        private double lateral2 = 0;
        private bool lateralesEspecificados = false;

        public FrmTrapecio()
        {
            InitializeComponent();
        }

        private void BtnCalcular_Click(object sender, EventArgs e)
        {
            // Parse required values
            if (!double.TryParse(txtBaseMay.Text, out B) || B <= 0)
            {
                MessageBox.Show("Ingrese una Base Mayor (B) válida.");
                return;
            }

            if (!double.TryParse(txtBaseMen.Text, out b) || b <= 0)
            {
                MessageBox.Show("Ingrese una Base Menor (b) válida.");
                return;
            }

            if (!double.TryParse(txtAltura.Text, out h) || h <= 0)
            {
                MessageBox.Show("Ingrese una Altura (h) válida.");
                return;
            }

            // Optional laterals
            bool l1OK = double.TryParse(txtLateral1.Text, out lateral1) && lateral1 > 0;
            bool l2OK = double.TryParse(txtLateral2.Text, out lateral2) && lateral2 > 0;

            lateralesEspecificados = l1OK && l2OK;

            // Area always uses B, b, h
            double area = (B + b) * h / 2.0;

            double perimetro;
            if (lateralesEspecificados)
            {
                perimetro = B + b + lateral1 + lateral2;
            }
            else
            {
                // assume isosceles: compute each lateral by Pythagoras
                // horizontal half-difference
                double halfDiff = Math.Abs(B - b) / 2.0;
                double lateralIso = Math.Sqrt(halfDiff * halfDiff + h * h);
                perimetro = B + b + 2 * lateralIso;

                // store the computed laterals for possible drawing/labeling
                lateral1 = lateral2 = lateralIso;
            }

            LblArea.Text = $"Área: {area:F2}";
            LblPerimetro.Text = $"Perimetro: {perimetro:F2}";

            // Redraw panel
            pnlTrapecio.Invalidate();
        }

        private void BtnResetear_Click(object sender, EventArgs e)
        {
            txtBaseMen.Text = "";
            txtAltura.Text = "";
            txtLateral1.Text = "";
            txtBaseMay.Text = "";
            txtLateral2.Text = "";
            LblPerimetro.Text = "Perimetro:";
            LblArea.Text = "Área:";

            B = b = h = lateral1 = lateral2 = 0;
            lateralesEspecificados = false;

            pnlTrapecio.Invalidate();
        }

        private void BtnSalir_Click(object sender, EventArgs e)
        {
            this.Close();
        }

        private void pnlTrapecio_Paint(object sender, PaintEventArgs e)
        {
            Graphics g = e.Graphics;
            g.SmoothingMode = SmoothingMode.AntiAlias;

            // clear panel
            g.Clear(pnlTrapecio.BackColor);

            if (B <= 0 || b <= 0 || h <= 0)
                return;

            // Work with positive bases: if b > B swap so B is larger visually
            double baseMayor = Math.Max(B, b);
            double baseMenor = Math.Min(B, b);

            // Determine scale so trapezoid fits inside panel with margin
            float margin = 0.9f; // use 90% of the smaller dimension
            float panelW = pnlTrapecio.ClientSize.Width;
            float panelH = pnlTrapecio.ClientSize.Height;

            // Desired sizes in 'units' are baseMayor (width) and h (height)
            double desiredW = baseMayor;
            double desiredH = h;

            // Compute scale to fit both width and height
            float scaleW = (float)((panelW * margin) / Math.Max(1.0, desiredW));
            float scaleH = (float)((panelH * margin) / Math.Max(1.0, desiredH));
            float scale = Math.Min(scaleW, scaleH);

            // If scale >=1 we will draw with exact units (no scaling up) but the user wanted growth
            // Make it so the shape grows with input but not exceed panel: allow scale=1 if fits, else scale down
            if (scale > 1f)
                scale = 1f; // do not upscale beyond actual units

            float drawBottom = (float)(baseMayor * scale);
            float drawTop = (float)(baseMenor * scale);
            float drawHeight = (float)(desiredH * scale);

            // Center shape inside panel
            float x0 = (panelW - drawBottom) / 2f; // left of bottom base
            float y0 = (panelH - drawHeight) / 2f;  // top y of shape

            // top base left x (centered relative to bottom base)
            float topLeftX = x0 + (drawBottom - drawTop) / 2f;

            PointF[] poly = new PointF[4];
            // bottom-left
            poly[0] = new PointF(x0, y0 + drawHeight);
            // bottom-right
            poly[1] = new PointF(x0 + drawBottom, y0 + drawHeight);
            // top-right
            poly[2] = new PointF(topLeftX + drawTop, y0);
            // top-left
            poly[3] = new PointF(topLeftX, y0);

            // Fill and draw
            using (Brush brush = new SolidBrush(Color.LightSalmon))
            {
                g.FillPolygon(brush, poly);
            }

            using (Pen pen = new Pen(Color.DarkBlue, 2))
            {
                g.DrawPolygon(pen, poly);
            }

            // Optionally draw lateral lengths if not specified (isosceles) or show given laterals
            using (Font f = new Font("Segoe UI", 8F))
            using (Brush textBrush = Brushes.Black)
            {
                string l1Text = $"L1: {lateral1:F2}";
                string l2Text = $"L2: {lateral2:F2}";
                g.DrawString(l1Text, f, textBrush, poly[0].X, poly[0].Y + 4);
                g.DrawString(l2Text, f, textBrush, poly[1].X - 40, poly[1].Y + 4);

                // Draw bases and height labels
                string bBot = $"B: {baseMayor:F2}";
                string bTop = $"b: {baseMenor:F2}";
                string hText = $"h: {h:F2}";
                g.DrawString(bBot, f, textBrush, x0 + drawBottom / 2f - 20, y0 + drawHeight + 4);
                g.DrawString(bTop, f, textBrush, topLeftX + drawTop / 2f - 20, y0 - 16);
                g.DrawString(hText, f, textBrush, x0 + drawBottom + 6, y0 + drawHeight / 2f - 8);
            }

            // Optional: draw panel bounds
            using (Pen boundsPen = new Pen(Color.FromArgb(80, Color.Gray), 1))
            {
                boundsPen.DashStyle = DashStyle.Dash;
                g.DrawRectangle(boundsPen, 0, 0, panelW - 1, panelH - 1);
            }
        }
    }
}
